{
  "name": "friday",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "python:test": "python3 -m unittest discover -s src-tauri/python_tests -p 'test_*.py' -v",
    "typecheck": "tsc --noEmit",
    "cargo:check": "cargo check --manifest-path src-tauri/Cargo.toml --locked",
    "cargo:test": "cargo test --manifest-path src-tauri/Cargo.toml --locked",
    "cargo:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --locked -- -D warnings",
    "check": "npm run typecheck && npm run test:run && npm run build && npm run cargo:check && npm run cargo:test",
    "tauri": "LLVM_PROFILE_FILE=/tmp/friday-%p.profraw tauri"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.164",
    "@ant-design/icons": "^6.0.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "ai": "^6.0.162",
    "antd": "^5",
    "katex": "^0.16.45",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^9",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^26.1.0",
    "typescript": "^5.7",
    "vite": "^6",
    "vitest": "^3.2.4"
  }
}
